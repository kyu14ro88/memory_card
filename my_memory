from PyQt5.QtCore import Qt
from PyQt5.QtGui import QPalette, QColor
from PyQt5.QtWidgets import (
    QApplication, QWidget,
    QHBoxLayout, QVBoxLayout,
    QGroupBox, QButtonGroup, QRadioButton,
    QPushButton, QLabel)
from random import shuffle




class Question():
    ''' Хранилище вопроса, правильного ответа и трех неправильных '''
    def __init__(self, question, right_answer, wrong1, wrong2, wrong3):
        self.question = question
        self.right_answer = right_answer
        self.wrong1 = wrong1
        self.wrong2 = wrong2
        self.wrong3 = wrong3




questions_list = [
    Question('Государственный язык Бразилии', 'Португальский', 'Английский', 'Испанский', 'Бразильский'),
    Question('Какого цвета нет на флаге России?', 'Зелёный', 'Красный', 'Белый', 'Синий'),
    Question('Национальная хижина якутов', 'Ураса', 'Юрта', 'Иглу', 'Хата'),
    Question('Кто написал роман "Война и мир"?', 'Лев Толстой', 'Федор Достоевский', 'Антон Чехов', 'Александр Пушкин'),
    Question('Как называется столица Австралии?', 'Канберра', 'Сидней', 'Мельбурн', 'Брисбен'),
    Question('Какой символ изображён на российском гербе?', 'Двуглавый орёл', 'Медведь', 'Волк', 'Конь'),
    Question('Самый глубокий океан Земли?', 'Тихий океан', 'Атлантический океан', 'Индийский океан', 'Северный Ледовитый океан'),
    Question('Сколько планет в Солнечной системе?', 'Восемь', 'Девять', 'Шесть Семь', 'Десять'),
    Question('Главный герой романа Ф.М. Достоевского "Преступление и наказание":', 'Родион Раскольников', 'Евгений Онегин', 'Илья Обломов', 'Алексей Каренин'),
    Question('Какой город называют культурной столицей России?', 'Санкт-Петербург', 'Москва', 'Екатеринбург', 'Новосибирск'),
    Question('Чем знаменит Эрмитаж?', 'Музей искусств', 'Театр оперы и балета', 'Библиотека', 'Научный институт'),
    Question('Назовите самую высокую гору мира:', 'Эверест', 'Эльбрус', 'Монблан', 'Большая гора'),
    Question('Автор картины "Черный квадрат":', 'Казимир Малевич', 'Василий Кандинский', 'Марк Шагал', 'Павел Филонов')
]




app = QApplication([])


# Цвет фона окна
palette = app.palette()
palette.setColor(QPalette.Window, QColor('#add8e6'))  # Голубой цвет
app.setPalette(palette)




btn_OK = QPushButton('Ответить')  # Кнопка ответа
lb_Question = QLabel('Вопрос')     # Заголовок вопроса




RadioGroupBox = QGroupBox("Варианты ответов")  # Группа для переключателей с ответами




rbtn_1 = QRadioButton('Вариант 1')
rbtn_2 = QRadioButton('Вариант 2')
rbtn_3 = QRadioButton('Вариант 3')
rbtn_4 = QRadioButton('Вариант 4')




RadioGroup = QButtonGroup()  # Радиогруппа для управления выбором
RadioGroup.addButton(rbtn_1)
RadioGroup.addButton(rbtn_2)
RadioGroup.addButton(rbtn_3)
RadioGroup.addButton(rbtn_4)




layout_ans1 = QHBoxLayout()
layout_ans2 = QVBoxLayout()  # Вертикальное расположение
layout_ans3 = QVBoxLayout()
layout_ans2.addWidget(rbtn_1)  # Первый столбец
layout_ans2.addWidget(rbtn_2)
layout_ans3.addWidget(rbtn_3)  # Второй столбец
layout_ans3.addWidget(rbtn_4)


layout_ans1.addLayout(layout_ans2)
layout_ans1.addLayout(layout_ans3)


RadioGroupBox.setLayout(layout_ans1)  # Подготовка группы с вариантами ответов




AnsGroupBox = QGroupBox("Результат теста")
lb_Result = QLabel('Ваш результат:')
lb_Correct = QLabel('Правильные ответы')




layout_res = QVBoxLayout()
layout_res.addWidget(lb_Result, alignment=(Qt.AlignLeft | Qt.AlignTop))
layout_res.addWidget(lb_Correct, alignment=Qt.AlignHCenter, stretch=2)
AnsGroupBox.setLayout(layout_res)
layout_line1 = QHBoxLayout()  # Первая строка (заголовок)
layout_line2 = QHBoxLayout()  # Вторая строка (варианты ответов или результат)
layout_line3 = QHBoxLayout()  # Третья строка (кнопка)


layout_line1.addWidget(lb_Question, alignment=(Qt.AlignHCenter | Qt.AlignVCenter))
layout_line2.addWidget(RadioGroupBox)
layout_line2.addWidget(AnsGroupBox)
AnsGroupBox.hide()  # Изначальное состояние: скрыть результаты


layout_line3.addStretch(1)
layout_line3.addWidget(btn_OK, stretch=2)  # Кнопка большого размера
layout_line3.addStretch(1)


layout_card = QVBoxLayout()


layout_card.addLayout(layout_line1, stretch=2)
layout_card.addLayout(layout_line2, stretch=8)
layout_card.addStretch(1)
layout_card.addLayout(layout_line3, stretch=1)
layout_card.addStretch(1)
layout_card.setSpacing(5)  # Промежутки между элементами




answers = [rbtn_1, rbtn_2, rbtn_3, rbtn_4]
current_question_idx = 0  # Индекс текущего вопроса




def ask(q: Question):
    ''' Заполнение формы новыми данными вопроса и ответов '''
    shuffle(answers)  # Перемешиваем ответы
    answers[0].setText(q.right_answer)  # Правильный ответ на первой позиции
    answers[1].setText(q.wrong1)
    answers[2].setText(q.wrong2)
    answers[3].setText(q.wrong3)
    lb_Question.setText(q.question)
    lb_Correct.setText(q.right_answer)
    show_question()




def show_result():
    ''' Переключаемся на страницу с результатом '''
    RadioGroupBox.hide()
    AnsGroupBox.show()
    btn_OK.setText('Следующий вопрос')




def show_question():
    ''' Возврат к форме с вопросами '''
    RadioGroupBox.show()
    AnsGroupBox.hide()
    btn_OK.setText('Ответить')
    RadioGroup.setExclusive(False)  # Удаляем выделение ранее выбранного ответа
    for rb in answers:
        rb.setChecked(False)
    RadioGroup.setExclusive(True)




def show_final_results():
    ''' Выводим финальное окно с результатами '''
    global current_question_idx
    result_text = f'Вы ответили правильно на {window.score}/{len(questions_list)} вопросов.'
    lb_Result.setText(result_text)
    lb_Correct.clear()  # Убираем предыдущий текст
    RadioGroupBox.hide()
    AnsGroupBox.show()
    btn_OK.hide()  # Прячем кнопку после завершения теста




def check_answer():
    ''' Проверка правильности ответа '''
    if answers[0].isChecked():  # Выбран правильный ответ
        show_correct('Верно!')
        window.score += 1
    elif any(rb.isChecked() for rb in answers[1:]):  # Неверный ответ
        show_correct('Неверно!')
    else:
        return  # Нет ответа, пропускаем
    print(f'Правильных ответов: {window.score}')




def show_correct(res):
    ''' Сообщение о правильном или неправильном ответе '''
    lb_Result.setText(res)
    show_result()




def next_question():
    ''' Переходим к следующему вопросу или завершаем тест '''
    global current_question_idx
    if current_question_idx < len(questions_list):
        q = questions_list[current_question_idx]
        ask(q)
        current_question_idx += 1
    else:
        show_final_results()




def click_OK():
    ''' Обработка события нажатия кнопки "Ответить" или "Следующий вопрос" '''
    if btn_OK.text() == 'Ответить':
        check_answer()
    else:
        next_question()




window = QWidget()
window.setLayout(layout_card)
window.setWindowTitle('Викторина')


btn_OK.clicked.connect(click_OK)


window.score = 0
next_question()


window.resize(400, 300)
window.show()
app.exec()

